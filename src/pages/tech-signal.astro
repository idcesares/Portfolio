/* ═══════════════════════════════════════════════
   RENDER + STATE
═══════════════════════════════════════════════ */
const grid        = document.getElementById('grid');
const filterRow   = document.getElementById('filterRow');
const searchInput = document.getElementById('search');
const searchClear = document.getElementById('searchClear');
const emptyState  = document.getElementById('empty');
const resultTitle = document.getElementById('resultTitle');
const resultCount = document.getElementById('resultCount');
const tierSeg     = document.getElementById('tierSeg');

let activeFilter = 'all';
let activeTier   = 'all';
let searchTerm   = '';

const TIER_NAME  = { 1: 'Essential', 2: 'Strong', 3: 'Situational' };
const TIER_LABEL = {
  1: 'Essential — non-negotiable daily read',
  2: 'Strong — excellent, depends on your role',
  3: 'Situational — reach for when you need it'
};

const escapeHTML = s => s.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));

function highlight(text, term) {
  const safe = escapeHTML(text);
  if (!term) return safe;
  const re = new RegExp('(' + term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
  return safe.replace(re, '<mark>$1</mark>');
}

function countFor(catId) {
  if (catId === 'all') return SOURCES.length;
  return SOURCES.filter(s => s.cats.includes(catId)).length;
}

// Build filter pills
CATEGORIES.forEach(cat => {
  const btn = document.createElement('button');
  btn.className = 'filter-pill' + (cat.id === 'all' ? ' active' : '');
  btn.dataset.filter = cat.id;
  btn.setAttribute('aria-pressed', cat.id === 'all' ? 'true' : 'false');
  btn.innerHTML = `${cat.label} <span class="pill-count">${countFor(cat.id)}</span>`;
  btn.addEventListener('click', () => {
    activeFilter = cat.id;
    document.querySelectorAll('.filter-pill').forEach(p => {
      const on = p.dataset.filter === cat.id;
      p.classList.toggle('active', on);
      p.setAttribute('aria-pressed', on ? 'true' : 'false');
    });
    render();
  });
  filterRow.appendChild(btn);
});

function matchesSearch(s, term) {
  if (!term) return true;
  const hay = (s.name + ' ' + s.desc + ' ' + (s.topics||[]).join(' ') + ' ' + (s.region||'') + ' ' + s.url).toLowerCase();
  return hay.includes(term);
}

function cardHTML(s, i) {
  const tierClass = 't' + s.tier;
  const accessLabel = s.access === 'free' ? 'Free' : 'Paid';
  const accessClass = s.access === 'free' ? 'access-free' : 'access-paid';
  const topicTags = (s.topics || []).map(t => `<span class="tag tag-topic">${escapeHTML(t)}</span>`).join('');
  const regionTag = s.region ? `<span class="tag tag-region">${escapeHTML(s.region)}</span>` : '';
  const deepTag   = s.deep ? `<span class="tag tag-deep">Deep</span>` : '';
  const cleanUrl  = s.url.replace(/^https?:\/\//, '').replace(/\/$/, '');
  // Cap stagger index so a 34-card view still finishes quickly
  const stagger = Math.min(i, 14);
  return `
    <a class="card ${tierClass}" href="${s.url}" target="_blank" rel="noopener noreferrer" style="--i:${stagger}">
      <div class="card-head">
        <div class="card-title-wrap">
          <button class="card-tier" data-tier="${s.tier}" title="${TIER_LABEL[s.tier]} — click to filter" aria-label="${TIER_LABEL[s.tier]}, filter by this priority"><span class="tier-tick"></span>${TIER_NAME[s.tier]}</button>
          <h3 class="card-title">${highlight(s.name, searchTerm)}</h3>
        </div>
        <span class="card-arrow" aria-hidden="true">↗</span>
      </div>
      <p class="card-url">${escapeHTML(cleanUrl)}</p>
      <p class="card-desc">${highlight(s.desc, searchTerm)}</p>
      <div class="card-foot">
        <span class="tag tag-cadence">${escapeHTML(s.cadence)}</span>
        ${deepTag}${regionTag}${topicTags}
        <span class="access ${accessClass}">${accessLabel}</span>
      </div>
    </a>`;
}

function setTier(tier) {
  activeTier = tier;
  tierSeg.querySelectorAll('.tier-btn').forEach(b => {
    const on = b.dataset.tier === tier;
    b.classList.toggle('active', on);
    b.setAttribute('aria-pressed', on ? 'true' : 'false');
  });
  render();
}

function render() {
  const term = searchTerm.trim().toLowerCase();
  let list = SOURCES.filter(s => activeFilter === 'all' || s.cats.includes(activeFilter));
  list = list.filter(s => activeTier === 'all' || String(s.tier) === activeTier);
  list = list.filter(s => matchesSearch(s, term));

  // Sort: tier first, then alphabetical — keeps the strongest sources up top
  list.sort((a, b) => a.tier - b.tier || a.name.localeCompare(b.name));

  grid.innerHTML = list.map((s, i) => cardHTML(s, i)).join('');

  const catLabel = CATEGORIES.find(c => c.id === activeFilter).label;
  let title = activeFilter === 'all' ? 'All sources' : catLabel;
  if (activeTier !== 'all') title += ' · ' + TIER_NAME[activeTier];
  resultTitle.textContent = title;
  resultCount.textContent = list.length + (list.length === 1 ? ' source' : ' sources');

  const isEmpty = list.length === 0;
  emptyState.classList.toggle('visible', isEmpty);
  grid.style.display = isEmpty ? 'none' : 'grid';
}

// Tier segmented control
tierSeg.querySelectorAll('.tier-btn').forEach(btn => {
  btn.addEventListener('click', () => setTier(btn.dataset.tier));
});

// Clickable tier badges on cards (event delegation — cards are re-rendered)
grid.addEventListener('click', e => {
  const badge = e.target.closest('.card-tier');
  if (!badge) return;
  e.preventDefault();   // don't follow the card's link
  e.stopPropagation();
  // Toggle: clicking the active tier again clears it
  setTier(activeTier === badge.dataset.tier ? 'all' : badge.dataset.tier);
  window.scrollTo({ top: document.querySelector('.result-meta').offsetTop - 80, behavior: 'smooth' });
});

// Search wiring (debounced)
let searchTimer;
searchInput.addEventListener('input', e => {
  searchTerm = e.target.value;
  searchClear.classList.toggle('visible', searchTerm.length > 0);
  clearTimeout(searchTimer);
  searchTimer = setTimeout(render, 120);
});
searchClear.addEventListener('click', () => {
  searchTerm = '';
  searchInput.value = '';
  searchClear.classList.remove('visible');
  searchInput.focus();
  render();
});
searchInput.addEventListener('keydown', e => { if (e.key === 'Escape') searchClear.click(); });

document.getElementById('emptyReset').addEventListener('click', () => {
  activeFilter = 'all';
  searchTerm = '';
  searchInput.value = '';
  searchClear.classList.remove('visible');
  document.querySelectorAll('.filter-pill').forEach(p => {
    const on = p.dataset.filter === 'all';
    p.classList.toggle('active', on);
    p.setAttribute('aria-pressed', on ? 'true' : 'false');
  });
  setTier('all');   // also re-renders
});

// Keyboard shortcut: "/" focuses search
document.addEventListener('keydown', e => {
  if (e.key === '/' && document.activeElement !== searchInput) {
    e.preventDefault();
    searchInput.focus();
  }
});

// Stats
document.getElementById('statSources').textContent = SOURCES.length;
document.getElementById('footerCount').textContent = SOURCES.length + ' sources · curated June 2026';

/* ═══════════ THEME ═══════════ */
const html = document.documentElement;
const themeToggle = document.getElementById('themeToggle');
const moon = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>`;
const sun  = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>`;

function setTheme(mode) {
  html.setAttribute('data-theme', mode);
  themeToggle.innerHTML = mode === 'dark' ? sun : moon;
  themeToggle.setAttribute('aria-label', mode === 'dark' ? 'Switch to light mode' : 'Switch to dark mode');
}
const stored = localStorage.getItem('membrane-theme');
setTheme(stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches) ? 'dark' : 'light');
themeToggle.addEventListener('click', () => {
  const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
  localStorage.setItem('membrane-theme', next);
  setTheme(next);
});

// Initial render
render();
</script>
</body>
</html>
