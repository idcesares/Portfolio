---
import MainHead from '../components/MainHead.astro';
import {
  AUTHOR_NAME,
  SITE_DESCRIPTION,
  SITE_NAME,
  SOCIAL_LINKS,
} from '../utils/seo';

export const prerender = true;

const title = "Tech Signal Stack | Isaac D'Césares";
const description =
  'A curated, opinionated reference of high signal-to-noise technology, AI, engineering, business, policy, and newsletter sources for daily intelligence practice.';
const canonicalPath = '/tech-signal/';
const baseUrl = Astro.site ?? Astro.url;
const pageUrl = new URL(canonicalPath, baseUrl);
const siteUrl = new URL('/', baseUrl);
const image = '/favicon.svg';
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Tech Signal Stack',
  headline: 'Tech Signal Stack',
  description,
  url: pageUrl.toString(),
  inLanguage: 'en',
  dateModified: '2026-06-14',
  isPartOf: {
    '@type': 'WebSite',
    name: SITE_NAME,
    url: siteUrl.toString(),
    description: SITE_DESCRIPTION,
  },
  author: {
    '@type': 'Person',
    name: AUTHOR_NAME,
    url: siteUrl.toString(),
    sameAs: [SOCIAL_LINKS.linkedin, SOCIAL_LINKS.github],
  },
  publisher: {
    '@type': 'Person',
    name: AUTHOR_NAME,
    url: siteUrl.toString(),
  },
  about: [
    'Technology intelligence',
    'Artificial intelligence',
    'Software engineering',
    'Technology business strategy',
    'Technology policy',
    'Newsletters',
  ],
  mainEntity: {
    '@type': 'ItemList',
    name: 'Curated technology intelligence sources',
    description: 'A ranked directory of technology sources organized by category, priority tier, cadence, and access model.',
    numberOfItems: 35,
    itemListOrder: 'https://schema.org/ItemListOrderDescending',
  },
};
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<MainHead
  title={title}
  description={description}
  image={image}
  imageAlt="Isaac D'Césares icon used as social preview for Tech Signal Stack"
  locale="en_US"
  structuredData={structuredData}
/>
<meta name="language" content="en">
<link rel="alternate" hreflang="en" href={pageUrl.toString()}>
<link rel="alternate" hreflang="x-default" href={pageUrl.toString()}>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,600&family=Instrument+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style is:global>
/* ═══════════════════════════════════════════════
   MEMBRANE PALETTE — design tokens
   Source: idcesares/idcesares-design-system v1.1
═══════════════════════════════════════════════ */
:root {
  --color-terracotta:    #B35530;
  --color-terracotta-10: rgba(179,85,48,0.10);
  --color-terracotta-20: rgba(179,85,48,0.20);
  --color-teal:          #1B756D;
  --color-teal-10:       rgba(27,117,109,0.10);
  --color-teal-20:       rgba(27,117,109,0.20);
  --color-cream:         #FAF6EE;
  --color-charcoal:      #1A1B1F;
  --color-amber:         #D49A3A;
  --color-burgundy:      #7A3345;
  --color-sage:          #5A8A6E;

  --neutral-100: #F0EBE1;
  --neutral-200: #E2DCD2;
  --neutral-300: #C8C1B5;
  --neutral-400: #A39D93;
  --neutral-500: #7D776E;
  --neutral-600: #5C564E;
  --neutral-700: #3D3832;
  --neutral-800: #2A2622;

  --color-bg-primary:      var(--color-cream);
  --color-bg-secondary:    var(--neutral-100);
  --color-bg-tertiary:     var(--neutral-200);
  --color-border-default:  var(--neutral-200);
  --color-border-emphasis: var(--neutral-300);
  --color-text-primary:    var(--neutral-800);
  --color-text-secondary:  var(--neutral-600);
  --color-text-tertiary:   var(--neutral-400);

  --font-serif: 'Fraunces', Georgia, serif;
  --font-sans:  'Instrument Sans', Inter, 'Helvetica Neue', sans-serif;
  --font-mono:  'JetBrains Mono', 'Fira Code', Consolas, monospace;

  --text-display: clamp(2.25rem, 3.5vw + 1rem, 3.75rem);
  --text-h2:      clamp(1.5rem, 2vw + 0.75rem, 2rem);
  --text-h3:      clamp(1.25rem, 1.5vw + 0.5rem, 1.5rem);
  --text-h4:      clamp(1.125rem, 1vw, 1.25rem);

  --space-1: 0.25rem;  --space-2: 0.5rem;   --space-3: 0.75rem;
  --space-4: 1rem;     --space-5: 1.25rem;  --space-6: 1.5rem;
  --space-8: 2rem;     --space-10: 2.5rem;  --space-12: 3rem;
  --space-16: 4rem;    --space-20: 5rem;    --space-24: 6rem;

  --radius-sm: 4px;  --radius-md: 8px;  --radius-lg: 12px;
  --radius-xl: 16px; --radius-full: 999px;

  --shadow-sm: 0 1px 3px rgba(26,27,31,0.06), 0 1px 2px rgba(26,27,31,0.04);
  --shadow-md: 0 4px 12px rgba(26,27,31,0.08), 0 2px 4px rgba(26,27,31,0.04);
  --shadow-glow-warm: 0 0 24px rgba(179,85,48,0.15);
  --shadow-glow-teal: 0 0 24px rgba(27,117,109,0.15);

  --duration-fast: 150ms; --duration-normal: 250ms; --duration-slow: 400ms;
  --ease-default: cubic-bezier(0.25,0.1,0.25,1);
  --ease-out:     cubic-bezier(0,0,0.2,1);

  --gradient-membrane: linear-gradient(135deg, #B35530 0%, #1B756D 100%);
  --gradient-warmth:   radial-gradient(ellipse at 15% 0%, rgba(179,85,48,0.08) 0%, transparent 70%);

  --container: 1140px;
  --site-margin: clamp(1.25rem, 4vw, 4rem);
}

[data-theme="dark"] {
  --color-bg-primary:      #1A1B1F;
  --color-bg-secondary:    #242429;
  --color-bg-tertiary:     #2E2E34;
  --color-border-default:  #3D3842;
  --color-border-emphasis: #5C564E;
  --color-text-primary:    #F0EBE1;
  --color-text-secondary:  #A39D93;
  --color-text-tertiary:   #7D776E;
  --color-terracotta:      #D4724F;
  --color-teal:            #3AAFA8;
  --color-amber:           #E8B44A;
  --color-sage:            #6FBF8A;
  --color-terracotta-10:   rgba(212,114,79,0.12);
  --color-teal-10:         rgba(58,175,168,0.12);
  --shadow-sm: 0 1px 3px rgba(0,0,0,0.25), 0 1px 2px rgba(0,0,0,0.18);
  --shadow-md: 0 4px 12px rgba(0,0,0,0.3), 0 2px 4px rgba(0,0,0,0.2);
  --gradient-warmth: radial-gradient(ellipse at 15% 0%, rgba(212,114,79,0.06) 0%, transparent 70%);
}

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    transition-duration: 0ms !important;
    animation-duration: 0ms !important;
    animation-delay: 0ms !important;
    scroll-behavior: auto !important;
  }
}

/* ═══════════ MOTION ═══════════ */
@keyframes rise-in {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fade-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes header-in {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes line-grow {
  from { transform: scaleX(0); }
  to   { transform: scaleX(1); }
}

/* ═══════════ RESET & BASE ═══════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 16px; scroll-behavior: smooth; }
body {
  font-family: var(--font-sans);
  background: var(--color-bg-primary);
  background-image: var(--gradient-warmth);
  background-attachment: fixed;
  color: var(--color-text-primary);
  line-height: 1.6;
  min-height: 100vh;
  transition: background-color var(--duration-normal) var(--ease-default),
              color var(--duration-normal) var(--ease-default);
}
a { color: inherit; text-decoration: none; }
button { cursor: pointer; font-family: var(--font-sans); border: none; background: none; }

.skip-link {
  position: absolute; left: -999px; top: 0; z-index: 999;
  background: var(--color-terracotta); color: #fff;
  padding: var(--space-3) var(--space-5); border-radius: 0 0 var(--radius-md) 0;
  font-size: 0.875rem; font-weight: 500;
}
.skip-link:focus { left: 0; }

/* ═══════════ HEADER ═══════════ */
.site-header {
  background: var(--color-charcoal);
  position: relative; overflow: hidden;
  padding: var(--space-16) var(--site-margin) var(--space-12);
}
[data-theme="dark"] .site-header { background: #111217; }
.header-ambient {
  position: absolute; inset: 0; pointer-events: none;
  background:
    radial-gradient(ellipse at 8% 60%, rgba(179,85,48,0.20) 0%, transparent 50%),
    radial-gradient(ellipse at 88% 15%, rgba(27,117,109,0.16) 0%, transparent 48%);
}
.header-wordmark {
  position: absolute; bottom: -0.12em; right: -0.02em;
  font-family: var(--font-serif); font-weight: 700;
  font-size: clamp(5rem, 19vw, 13rem); line-height: 1;
  color: rgba(255,255,255,0.035); letter-spacing: -0.04em;
  pointer-events: none; user-select: none;
  font-variation-settings: "WONK" 1;
}
.header-inner {
  position: relative; z-index: 2;
  max-width: var(--container); margin: 0 auto;
  display: flex; flex-direction: column; gap: var(--space-5);
}
.header-inner > * { animation: header-in var(--duration-slow) var(--ease-out) both; }
.header-eyebrow   { animation-delay: 60ms; }
.header-headline  { animation-delay: 140ms; }
.header-meta      { animation-delay: 240ms; }
.header-eyebrow {
  font-size: 0.75rem; font-weight: 500; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--color-terracotta);
  display: flex; align-items: center; gap: var(--space-2);
}
.header-eyebrow::before {
  content: ''; width: 24px; height: 1px;
  background: var(--color-terracotta); opacity: 0.55;
}
.header-headline {
  font-family: var(--font-serif); font-weight: 700;
  font-size: var(--text-display); line-height: 1.04;
  letter-spacing: -0.025em; color: var(--color-cream);
  font-variation-settings: "WONK" 1; max-width: 16ch;
}
.header-headline em { font-style: italic; color: var(--color-amber); }
.header-meta {
  display: flex; align-items: flex-end; justify-content: space-between;
  gap: var(--space-10); flex-wrap: wrap;
}
.header-desc {
  font-size: 1.0625rem; color: rgba(240,235,225,0.6);
  max-width: 54ch; line-height: 1.65;
}
.header-stats { display: flex; gap: var(--space-8); flex-shrink: 0; }
.stat { display: flex; flex-direction: column; gap: 2px; }
.stat-num {
  font-family: var(--font-serif); font-size: 1.875rem; font-weight: 700;
  color: var(--color-cream); line-height: 1; font-variation-settings: "WONK" 1;
}
.stat-label {
  font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.08em;
  text-transform: uppercase; color: rgba(240,235,225,0.4);
}
.membrane-line {
  height: 3px; background: var(--gradient-membrane);
  transform-origin: left center;
  animation: line-grow var(--duration-slower, 600ms) var(--ease-out) 360ms both;
}

/* ═══════════ CONTROLS (sticky) ═══════════ */
.controls {
  position: sticky; top: 0; z-index: 100;
  background: color-mix(in srgb, var(--color-bg-secondary) 88%, transparent);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--color-border-default);
  transition: background-color var(--duration-normal), border-color var(--duration-normal);
}
.controls-inner {
  max-width: var(--container); margin: 0 auto;
  padding: var(--space-3) var(--site-margin);
  display: flex; flex-direction: column; gap: var(--space-3);
}
.controls-top {
  display: flex; align-items: center; gap: var(--space-3);
}
/* Search */
.search-wrap {
  flex: 1; position: relative; display: flex; align-items: center;
  min-width: 0;
}
.search-icon {
  position: absolute; left: var(--space-3); color: var(--color-text-tertiary);
  pointer-events: none; display: flex;
}
.search-input {
  width: 100%; font-family: var(--font-sans); font-size: 0.9375rem;
  color: var(--color-text-primary);
  background: var(--color-bg-primary);
  border: 1px solid var(--color-border-default);
  border-radius: var(--radius-full);
  padding: var(--space-2) var(--space-10) var(--space-2) 2.5rem;
  transition: border-color var(--duration-fast), box-shadow var(--duration-fast);
}
.search-input::placeholder { color: var(--color-text-tertiary); }
.search-input:focus {
  outline: none; border-color: var(--color-teal);
  box-shadow: 0 0 0 3px var(--color-teal-10);
}
.search-clear {
  position: absolute; right: var(--space-2);
  width: 24px; height: 24px; border-radius: 50%;
  display: none; align-items: center; justify-content: center;
  color: var(--color-text-tertiary);
  transition: background var(--duration-fast), color var(--duration-fast);
}
.search-clear:hover { background: var(--color-bg-tertiary); color: var(--color-text-primary); }
.search-clear.visible { display: flex; }
.theme-toggle {
  width: 38px; height: 38px; flex-shrink: 0;
  border: 1px solid var(--color-border-default); border-radius: var(--radius-md);
  color: var(--color-text-secondary);
  display: flex; align-items: center; justify-content: center;
  transition: all var(--duration-fast) var(--ease-default);
}
.theme-toggle:hover { background: var(--color-bg-tertiary); color: var(--color-text-primary); }
.theme-toggle:focus-visible { outline: 2px solid var(--color-teal); outline-offset: 2px; }

/* Filter pills */
.filter-row {
  display: flex; gap: var(--space-2); overflow-x: auto;
  scrollbar-width: none; -ms-overflow-style: none;
  padding-bottom: 2px;
}
.filter-row::-webkit-scrollbar { display: none; }
.filter-pill {
  font-size: 0.78rem; font-weight: 500; letter-spacing: 0.01em;
  color: var(--color-text-secondary);
  background: var(--color-bg-primary);
  border: 1px solid var(--color-border-default);
  padding: var(--space-2) var(--space-4);
  border-radius: var(--radius-full); white-space: nowrap;
  display: flex; align-items: center; gap: var(--space-2);
  transition: all var(--duration-fast) var(--ease-default);
}
.filter-pill:hover {
  border-color: var(--color-border-emphasis);
  color: var(--color-text-primary);
}
.filter-pill.active {
  background: var(--color-terracotta); border-color: var(--color-terracotta);
  color: #fff;
}
.filter-pill .pill-count {
  font-family: var(--font-mono); font-size: 0.62rem;
  opacity: 0.65; font-weight: 400;
}
.filter-pill.active .pill-count { opacity: 0.85; }
.filter-pill:focus-visible { outline: 2px solid var(--color-teal); outline-offset: 2px; }

/* ═══════════ MAIN ═══════════ */
main { max-width: var(--container); margin: 0 auto; padding: var(--space-10) var(--site-margin) var(--space-24); }

/* Strategy panel */
.strategy {
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border-default);
  border-radius: var(--radius-xl);
  padding: var(--space-6) var(--space-8);
  animation: rise-in var(--duration-slow) var(--ease-out) 440ms both;
  margin-bottom: var(--space-10);
  display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6);
  position: relative; overflow: hidden;
}
.strategy::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: var(--gradient-membrane);
}
.strat-item { display: flex; flex-direction: column; gap: var(--space-1); }
.strat-label {
  font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.08em;
  text-transform: uppercase; color: var(--color-text-tertiary);
}
.strat-title {
  font-family: var(--font-serif); font-size: 1.0625rem; font-weight: 600;
  color: var(--color-text-primary); font-variation-settings: "WONK" 1;
  display: flex; align-items: center; gap: var(--space-2);
}
.strat-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
.dot-t { background: var(--color-terracotta); }
.dot-a { background: var(--color-amber); }
.dot-d { background: var(--color-teal); }
.strat-desc { font-size: 0.8125rem; color: var(--color-text-secondary); line-height: 1.5; }

/* Result meta line */
.result-meta {
  display: flex; align-items: center; justify-content: space-between;
  gap: var(--space-4); margin-bottom: var(--space-5); flex-wrap: wrap;
}
.result-meta-left { display: flex; align-items: baseline; gap: var(--space-3); flex-wrap: wrap; }
.result-title {
  font-family: var(--font-serif); font-size: var(--text-h3); font-weight: 600;
  color: var(--color-text-primary); font-variation-settings: "WONK" 1;
}
.result-count {
  font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-text-tertiary);
}

/* Tier segmented control */
.tier-control {
  display: inline-flex; align-items: center; gap: var(--space-2);
  min-width: 0;
}
.tier-control-label {
  font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.08em;
  text-transform: uppercase; color: var(--color-text-tertiary);
  margin-right: var(--space-1); flex-shrink: 0;
}
.tier-seg {
  display: inline-flex; background: var(--color-bg-secondary);
  border: 1px solid var(--color-border-default); border-radius: var(--radius-full);
  padding: 3px; max-width: 100%; overflow-x: auto;
  scrollbar-width: none; -ms-overflow-style: none;
}
.tier-seg::-webkit-scrollbar { display: none; }
.tier-btn {
  font-family: var(--font-sans); font-size: 0.72rem; font-weight: 500;
  color: var(--color-text-secondary);
  padding: var(--space-1) var(--space-3); border-radius: var(--radius-full);
  display: inline-flex; align-items: center; gap: var(--space-1);
  transition: all var(--duration-fast) var(--ease-default);
  white-space: nowrap;
}
.tier-btn:hover { color: var(--color-text-primary); }
.tier-btn .tier-tick { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
.tier-btn[data-tier="1"] .tier-tick { background: var(--color-terracotta); }
.tier-btn[data-tier="2"] .tier-tick { background: var(--color-teal); }
.tier-btn[data-tier="3"] .tier-tick { background: var(--neutral-300); }
.tier-btn.active { background: var(--color-bg-tertiary); color: var(--color-text-primary); }
.tier-btn.active[data-tier="1"] { background: var(--color-terracotta-10); color: var(--color-terracotta); }
.tier-btn.active[data-tier="2"] { background: var(--color-teal-10); color: var(--color-teal); }
.tier-btn:focus-visible { outline: 2px solid var(--color-teal); outline-offset: 2px; }

/* ═══════════ CARD GRID ═══════════ */
.grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: var(--space-4);
}
.card {
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border-default);
  border-radius: var(--radius-lg);
  padding: var(--space-5) var(--space-6);
  display: flex; flex-direction: column; gap: var(--space-3);
  position: relative; overflow: hidden;
  transition: transform var(--duration-slow) var(--ease-out),
              box-shadow var(--duration-slow) var(--ease-out),
              border-color var(--duration-normal) var(--ease-default),
              background-color var(--duration-normal) var(--ease-default);
  animation: rise-in var(--duration-slow) var(--ease-out) both;
  animation-delay: calc(var(--i, 0) * 28ms);
}
.card::before {
  content: ''; position: absolute; top: 0; left: 0;
  width: 3px; height: 100%;
}
.card.t1::before { background: var(--color-terracotta); }
.card.t2::before { background: var(--color-teal); }
.card.t3::before { background: var(--neutral-300); }
.card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); border-color: var(--color-border-emphasis); }
.card.t1:hover { box-shadow: var(--shadow-md), var(--shadow-glow-warm); }
.card.t2:hover { box-shadow: var(--shadow-md), var(--shadow-glow-teal); }
.card:focus-visible { outline: 2px solid var(--color-teal); outline-offset: 2px; }
.card:hover .card-arrow { opacity: 1; color: var(--color-terracotta); transform: translate(3px,-3px); }

.card-head { display: flex; justify-content: space-between; align-items: flex-start; gap: var(--space-2); }
.card-title-wrap { display: flex; flex-direction: column; gap: var(--space-1); flex: 1; min-width: 0; }
.card-tier {
  align-self: flex-start;
  font-family: var(--font-sans); font-size: 0.64rem; font-weight: 500;
  letter-spacing: 0.02em;
  padding: 2px var(--space-2); border-radius: var(--radius-full);
  display: inline-flex; align-items: center; gap: 5px;
  cursor: pointer; border: 1px solid transparent;
  transition: all var(--duration-fast) var(--ease-default);
}
.card-tier .tier-tick { width: 6px; height: 6px; border-radius: 50%; }
.card-tier[data-tier="1"] { background: var(--color-terracotta-10); color: var(--color-terracotta); }
.card-tier[data-tier="1"] .tier-tick { background: var(--color-terracotta); }
.card-tier[data-tier="2"] { background: var(--color-teal-10); color: var(--color-teal); }
.card-tier[data-tier="2"] .tier-tick { background: var(--color-teal); }
.card-tier[data-tier="3"] { background: var(--color-bg-tertiary); color: var(--color-text-tertiary); }
.card-tier[data-tier="3"] .tier-tick { background: var(--neutral-300); }
.card-tier:hover { border-color: currentColor; }
.card-tier:focus-visible { outline: 2px solid var(--color-teal); outline-offset: 2px; }
.card-title {
  font-family: var(--font-serif); font-size: var(--text-h4); font-weight: 600;
  color: var(--color-text-primary); line-height: 1.2;
  font-variation-settings: "WONK" 1;
}
.card-arrow {
  font-size: 12px; color: var(--color-text-tertiary); flex-shrink: 0; margin-top: 3px;
  opacity: 0; transition: opacity var(--duration-fast), transform var(--duration-fast), color var(--duration-fast);
}
.card-url { font-family: var(--font-mono); font-size: 0.65rem; color: var(--color-text-tertiary); letter-spacing: 0.01em; }
.card-desc { font-size: 0.84rem; color: var(--color-text-secondary); line-height: 1.55; flex: 1; }
.card-foot { display: flex; flex-wrap: wrap; gap: var(--space-2); align-items: center; margin-top: var(--space-1); }
.tag {
  font-size: 0.62rem; font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase;
  padding: 2px var(--space-3); border-radius: var(--radius-full); line-height: 1.7;
}
.tag-cadence { background: var(--color-terracotta-10); color: var(--color-terracotta); }
.tag-deep    { background: var(--color-teal-10);       color: var(--color-teal); }
.tag-topic   { background: var(--color-bg-tertiary);   color: var(--color-text-tertiary); }
.tag-region  { background: rgba(90,138,110,0.14);      color: var(--color-sage); }
.access {
  margin-left: auto; font-family: var(--font-mono); font-size: 0.6rem;
  letter-spacing: 0.04em; text-transform: uppercase;
  padding: 2px var(--space-2); border-radius: var(--radius-sm);
}
.access-free { background: rgba(90,138,110,0.15); color: var(--color-sage); }
.access-paid { background: rgba(212,154,58,0.16); color: var(--color-amber); }

/* Highlight (search match) */
mark { background: var(--color-amber); color: var(--color-charcoal); border-radius: 2px; padding: 0 1px; }

/* Empty state */
.empty {
  display: none; text-align: center; padding: var(--space-20) var(--space-4);
  color: var(--color-text-tertiary);
}
.empty.visible { display: block; }
.empty-glyph {
  font-family: var(--font-serif); font-size: 3rem; font-weight: 700;
  color: var(--color-border-emphasis); font-variation-settings: "WONK" 1;
  margin-bottom: var(--space-4);
}
.empty-text { font-size: 1rem; margin-bottom: var(--space-2); color: var(--color-text-secondary); }
.empty-sub { font-size: 0.875rem; }
.empty-reset {
  margin-top: var(--space-5); font-size: 0.875rem; font-weight: 500;
  color: var(--color-teal); border-bottom: 1px solid transparent;
  transition: border-color var(--duration-fast);
}
.empty-reset:hover { border-bottom-color: var(--color-teal); }

/* ═══════════ FOOTER ═══════════ */
.site-footer { border-top: 1px solid var(--color-border-default); padding: var(--space-8) var(--site-margin); }
.footer-inner {
  max-width: var(--container); margin: 0 auto;
  display: flex; justify-content: space-between; align-items: center;
  gap: var(--space-4); flex-wrap: wrap;
}
.footer-brand {
  font-family: var(--font-serif); font-weight: 700; font-size: 1rem;
  font-variation-settings: "WONK" 1; color: var(--color-terracotta);
}
.footer-brand .sep { color: var(--color-teal); }
.footer-brand .sub { font-family: var(--font-sans); font-weight: 400; font-size: 0.75rem; color: var(--color-text-tertiary); margin-left: var(--space-2); }
.footer-note { font-family: var(--font-mono); font-size: 0.65rem; color: var(--color-text-tertiary); letter-spacing: 0.03em; }

/* ═══════════ RESPONSIVE ═══════════ */
@media (max-width: 820px) {
  .strategy { grid-template-columns: 1fr; gap: var(--space-5); }
  .header-meta { flex-direction: column; align-items: flex-start; gap: var(--space-6); }
}
@media (max-width: 560px) {
  .header-stats { gap: var(--space-6); }
  .grid { grid-template-columns: 1fr; }
  .footer-inner { flex-direction: column; align-items: flex-start; }
