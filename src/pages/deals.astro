---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Grid from '../components/Grid.astro';

const deals = [
  {
    title: 'Perplexity Pro',
    description: 'Meu buscador com IA do dia a dia. Use o código de indicação "HEUYI5O6" no cadastro pra ganhar um mês Pro grátis.',
    link: 'https://www.perplexity.ai/pro?referral_code=HEUYI5O6',
  },
  {
    title: 'Beacons',
    description: 'Ferramenta simples pra montar página de links personalizada. Usando o código "idcesares" você libera recursos pagos por um tempo.',
    link: 'https://beacons.ai/signup?c=idcesares',
  },
{
    title: 'You.com',
    description: 'Interface de chat com acesso a vários modelos de IA num lugar só. O link de indicação te dá um período estendido pra testar.',
    link: 'https://you.com/join/XWF8WJ5T',
},
{
    title: 'Lovable',
    description: 'Plataforma pra gerar apps funcionais por prompt. Meu convite abre acesso à fila prioritária.',
    link: 'https://lovable.dev/invite/13eee9bc-6d52-46de-b6af-8f12534a7a42',
}];

---
<BaseLayout title="Indico e uso | Isaac D'Césares" description="Ferramentas digitais que uso e recomendo, com cupons e links de indicação quando disponíveis.">
    <div class="stack gap-20">
        <main class="wrapper stack gap-8">
            <Hero
                title="Indico e uso"
                tagline="Ferramentas que eu uso no dia a dia. Alguns links dão desconto ou benefício, outros são só registro do que funciona."
                align="start"
            />
            <Grid variant="offset" data-animate="fade-up">
                {
                    deals.map((deal) => (
                        <li class="deal-item">
                            <h3>{deal.title}</h3>
                            <p>{deal.description}</p>
                            <a href={deal.link} class="deal-button" target="_blank" rel="noopener noreferrer">Abrir link</a>
                        </li>
                    ))
                }
            </Grid>
        </main>
    </div>
</BaseLayout>

<style>
    .deal-item {
        padding: var(--space-6);
        background: var(--color-teal);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-md);
        text-align: left;
        color: var(--color-text-on-accent);
    }

    .deal-item h3 {
        font-size: var(--text-lg);
        font-family: var(--font-serif);
        margin-bottom: var(--space-2);
    }

    .deal-item p {
        font-size: var(--text-md);
        margin-bottom: var(--space-4);
    }

    .deal-button {
        display: inline-block;
        background: var(--color-terracotta);
        color: var(--color-text-on-accent);
        padding: var(--space-3) var(--space-6);
        border-radius: var(--radius-md);
        text-align: center;
        font-weight: bold;
        text-decoration: none;
        box-shadow: var(--shadow-sm);
        transition: background var(--duration-normal) var(--ease-out);
    }

    .deal-button:hover {
        background: var(--color-terracotta-light);
    }
</style>
