---
export const prerender = true;

import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página não encontrada | Isaac D'Césares" description="Erro 404: essa página não existe ou foi movida.">
	<Hero title="404: rota não encontrada" tagline="Alguma coisa no roteamento quebrou. Pode ser link antigo, typo, ou só um bit teimoso.">
		<p>Se você veio de um link meu, me avisa. Se veio do Google, o índice ainda não pegou essa mudança. Enquanto isso:</p>
		<a href="/" class="btn-primary mt-4 inline-block">Voltar pra home</a>
	</Hero>
</BaseLayout>
