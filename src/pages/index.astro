---
export const prerender = true;

import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

import CallToAction from '../components/CallToAction.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';

import ContactCTA from '../components/ContactCTA.astro';
import Skills from '../components/Skills.astro';
import PostPreview from '../components/PostPreview.astro';

import Portrait from '../assets/portrait.webp';

import { University } from '@lucide/astro';
import { getSiteStructuredData } from '../utils/seo';


const projects = (await getCollection('work'))
	.sort((a, b) => b.data.updatedDate.valueOf() - a.data.updatedDate.valueOf())
	.slice(0, 4);

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.updatedDate.valueOf() - a.data.updatedDate.valueOf())
	.slice(0, 4);

const site = Astro.site ?? new URL('https://dcesares.dev');
const structuredData = getSiteStructuredData(site);

---

<BaseLayout structuredData={structuredData}>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero" data-animate="fade-up">
				<Hero
					title="Isaac D'Césares"
					tagline="Traduzo tecnologias emergentes em experiências que transformam como pessoas e instituições aprendem."
					align="start"
				>
					<div class="roles" data-animate-stagger>
						<Pill color="terracotta"><Icon icon="book-open" size="1.33em" /> Pesquisador</Pill>
						<Pill color="sage"><University /> Educador</Pill>
						<Pill color="teal"><Icon icon="terminal-window" size="1.33em" /> Construtor</Pill>
					</div>

					<div class="hero-actions">
						<CallToAction href="/work/">
							Ver projetos
							<Icon icon="arrow-right" size="1.2em" />
						</CallToAction>
						<a class="ghost-link" href="/about/">Sobre mim</a>
					</div>
					
				</Hero>

				<img
					class="portrait"
					alt="Isaac D'Césares profile picture"
					src={Portrait.src}
					loading="eager"
					width="400"
					height="300"
					decoding="async"
					data-animate="scale-up"
					data-animate-delay="200"
				/>
			</header>

			<Skills />
		</div>

		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="section with-background with-cta" data-animate="fade-up">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Últimas postagens</h3>
					<p>Leia alguns dos meus artigos mais recentes sobre tecnologia, educação e desenvolvimento.</p>
				</header>

				<div class="gallery" data-animate-stagger>
					<Grid variant="offset">
						{
							posts.map((post) => (
								<li data-animate="fade-up">
									<PostPreview post={post} />
								</li>
							))
						}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/blog/">
						Ver todas
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>
		</main>

		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="section with-background with-cta" data-animate="fade-up">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Últimos trabalhos</h3>
					<p>Veja alguns dos meus mais recentes trabalhos e publicações.</p>
				</header>

				<div class="gallery" data-animate-stagger>
					<Grid variant="offset">
						{
							projects.map((project) => (
								<li data-animate="fade-up">
									<PortfolioPreview project={project} />
								</li>
							))
						}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/work/">
						Ver todos
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>
		</main>

		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="section with-background bg-variant" data-animate="fade-up">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Impacto e Alcance</h3>
					<p>Alguns números que demonstram o impacto do meu trabalho em tecnologia educacional.</p>
				</header>

				<div class="stats-grid" data-animate-stagger>
					<div class="stat-card" data-animate="scale-up">
						<div class="stat-number">2000+</div>
						<div class="stat-label">Educadores Impactados</div>
					</div>
					<div class="stat-card" data-animate="scale-up">
						<div class="stat-number">50+</div>
						<div class="stat-label">Projetos Desenvolvidos</div>
					</div>
					<div class="stat-card" data-animate="scale-up">
						<div class="stat-number">10+</div>
						<div class="stat-label">Instituições Parceiras</div>
					</div>
					<div class="stat-card" data-animate="scale-up">
						<div class="stat-number">10+</div>
						<div class="stat-label">Anos de Experiência</div>
					</div>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-8);
	}

	.roles {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	.hero img {
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: top;
		border-radius: var(--radius-xl);
		box-shadow: var(--shadow-md);
		filter: var(--photo-warmth);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
		align-items: center;
	}

	.ghost-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: var(--space-3) var(--space-6);
		border-radius: var(--radius-full);
		border: 1px solid var(--color-border-default);
		color: var(--color-text-secondary);
		text-decoration: none;
		font-family: var(--font-sans);
		font-weight: var(--weight-medium);
		transition: all var(--transition-default);
		background: color-mix(in oklab, var(--color-bg-primary) 80%, transparent);
		box-shadow: var(--shadow-sm);
		min-height: 44px;
	}

	.ghost-link:hover {
		color: var(--color-text-primary);
		border-color: var(--color-border-emphasis);
		transform: translateY(-1px);
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: var(--space-10);
			gap: var(--space-16);
		}

		.roles {
			margin-top: var(--space-2);
			gap: var(--space-2);
		}

		.hero img {
			aspect-ratio: 3 / 4;
			border-radius: var(--radius-xl);
			object-fit: cover;
		}
	}

	/* ====================================================== */

	.section {
		display: grid;
		gap: var(--space-8);
	}

	.with-background {
		position: relative;
	}

	.with-background::before {
		content: '';
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		height: 140%;
		top: -40%;
		transform: translateX(-50%);
		background:
			radial-gradient(800px 400px at 50% 10%, var(--color-terracotta-10), transparent 70%),
			radial-gradient(600px 300px at 80% 20%, var(--color-teal-08), transparent 65%);
		opacity: var(--opacity-heavy);
		z-index: -1;
	}

	.with-background.bg-variant::before {
		background:
			radial-gradient(800px 400px at 40% 10%, var(--color-teal-12), transparent 70%),
			radial-gradient(600px 300px at 70% 20%, var(--color-sage-10), transparent 65%);
	}

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
		font-size: var(--text-body-lg);
		color: var(--color-text-secondary);
	}

	.section-header h3 {
		font-size: var(--text-h1);
		letter-spacing: var(--tracking-heading);
	}

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
			gap: var(--space-20);
		}

		.section.with-cta {
			grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
		}

		.section-header {
			grid-area: header;
			font-size: var(--text-h3);
		}

		.section-header h3 {
			font-size: var(--text-display);
		}

		.with-cta .section-header {
			justify-self: flex-start;
			text-align: left;
		}

		.gallery {
			grid-area: gallery;
		}

		.cta {
			grid-area: cta;
		}
	}

	/* ====================================================== */

	.mention-card {
		display: flex;
		height: 7rem;
		justify-content: center;
		align-items: center;
		text-align: center;
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-xl);
		color: var(--color-text-secondary);
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-sm);
	}

	@media (min-width: 50em) {
		.mention-card {
			border-radius: var(--radius-xl);
			height: 9.5rem;
		}
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: var(--space-8);
		margin-top: var(--space-8);
		align-items: stretch;
		grid-auto-rows: 1fr;
	}

	.stat-card {
		text-align: center;
		padding: var(--space-8) var(--space-4);
		background: color-mix(in oklab, var(--color-bg-primary) 88%, transparent);
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-sm);
		transition: transform var(--transition-default),
			box-shadow var(--transition-default);
		width: 100%;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.stat-card:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-md);
	}

	.stat-number {
		font-size: var(--text-display);
		font-weight: var(--weight-bold);
		color: var(--color-terracotta);
		line-height: var(--leading-display);
		margin-bottom: var(--space-2);
		font-family: var(--font-serif);
	}

	.stat-label {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		font-weight: var(--weight-medium);
		text-transform: uppercase;
		letter-spacing: var(--tracking-label);
	}

	@media (min-width: 50em) {
		.stats-grid {
			grid-column: 1 / -1;
			grid-template-columns: repeat(4, 1fr);
			gap: var(--space-12);
		}

		.stat-card {
			padding: var(--space-12) var(--space-8);
			max-width: none;
		}

		.stat-label {
			font-size: var(--text-body);
		}
	}
</style>
