---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactCTA from '../components/ContactCTA.astro';
import DevProjectCard from '../components/DevProjectCard.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import { devProjects } from '../data/dev-projects';

const featured = devProjects.filter((p) => p.featured);
const others = devProjects.filter((p) => !p.featured);

const allTech = [
	...new Set(devProjects.flatMap((p) => p.techStack.map((t) => t.name))),
];
---

<BaseLayout
	title="Dev | Isaac D'Césares"
	description="Projetos de desenvolvimento de Isaac D'Césares: código, design systems e ferramentas construídas com propósito."
>
	<div class="stack gap-20" data-page-type="dev">
		<main class="wrapper stack gap-16">
			<Hero
				title="Dev"
				tagline="Código que resolve problemas reais. Open source, design systems e ferramentas de uso próprio."
				align="start"
			>
				<div class="hero-pills" data-animate="fade-up">
					<Pill color="teal"><Icon icon="terminal-window" size="1.2em" /> Full Stack</Pill>
					<Pill color="terracotta"><Icon icon="code" size="1.2em" /> Open Source</Pill>
					<Pill color="sage"><Icon icon="rocket-launch" size="1.2em" /> Deploy</Pill>
				</div>
			</Hero>

			{featured.length > 0 && (
				<section class="featured-section" data-animate="fade-up">
					<div class="section-label">
						<span class="label-line" aria-hidden="true"></span>
						<span class="label-text">Destaque</span>
						<span class="label-line" aria-hidden="true"></span>
					</div>
					{featured.map((project) => (
						<DevProjectCard project={project} variant="featured" />
					))}
				</section>
			)}

			{others.length > 0 && (
				<section class="projects-section" data-animate="fade-up">
					<div class="section-label">
						<span class="label-line" aria-hidden="true"></span>
						<span class="label-text">Projetos</span>
						<span class="label-line" aria-hidden="true"></span>
					</div>
					<div class="projects-grid">
						{others.map((project) => (
							<DevProjectCard project={project} variant="default" />
						))}
					</div>
				</section>
			)}

			<section class="tech-section" data-animate="fade-up">
				<div class="section-label">
					<span class="label-line" aria-hidden="true"></span>
					<span class="label-text">Tecnologias</span>
					<span class="label-line" aria-hidden="true"></span>
				</div>
				<p class="tech-intro">
					Ferramentas e frameworks que uso para transformar ideias em código que funciona.
				</p>
				<div class="tech-cloud">
					{allTech.map((tech) => (
						<span class="tech-tag">{tech}</span>
					))}
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.hero-pills {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	/* ========================================
	   Section Labels
	   ======================================== */

	.section-label {
		display: flex;
		align-items: center;
		gap: var(--space-4);
		margin-bottom: var(--space-8);
	}

	.label-line {
		flex: 1;
		height: 1px;
		background: var(--gradient-divider);
	}

	.label-text {
		font-size: var(--text-xs);
		font-weight: var(--weight-semibold);
		color: var(--color-text-tertiary);
		text-transform: uppercase;
		letter-spacing: var(--tracking-label);
		white-space: nowrap;
	}

	/* ========================================
	   Featured Section
	   ======================================== */

	.featured-section {
		display: flex;
		flex-direction: column;
	}

	/* ========================================
	   Projects Grid
	   ======================================== */

	.projects-section {
		display: flex;
		flex-direction: column;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-8);
	}

	@media (min-width: 50em) {
		.projects-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: var(--space-10);
		}
	}

	@media (min-width: 75em) {
		.projects-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	/* ========================================
	   Tech Cloud Section
	   ======================================== */

	.tech-section {
		position: relative;
	}

	.tech-section::before {
		content: '';
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		height: 160%;
		top: -30%;
		transform: translateX(-50%);
		background:
			radial-gradient(700px 350px at 50% 30%, var(--color-teal-08), transparent 65%),
			radial-gradient(500px 250px at 20% 50%, var(--bg-glow-terracotta), transparent 60%);
		opacity: var(--opacity-heavy);
		z-index: -1;
	}

	.tech-intro {
		text-align: center;
		color: var(--color-text-secondary);
		font-size: var(--text-body-lg);
		max-width: 50ch;
		margin: 0 auto var(--space-8);
	}

	.tech-cloud {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: var(--space-3);
	}

	.tech-tag {
		display: inline-flex;
		align-items: center;
		padding: var(--space-2) var(--space-5);
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text-secondary);
		background: color-mix(in oklab, var(--color-bg-primary) 85%, transparent);
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-full);
		transition:
			border-color var(--transition-default),
			color var(--transition-default),
			transform var(--transition-fast);
		min-height: 44px;
	}

	.tech-tag:hover {
		color: var(--color-teal);
		border-color: var(--color-teal-20);
		transform: translateY(-2px);
	}
</style>
