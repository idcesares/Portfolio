---
import type { DevProject } from '../data/dev-projects';
import { statusLabels, statusColors } from '../data/dev-projects';
import Icon from './Icon.astro';

interface Props {
	project: DevProject;
	variant?: 'featured' | 'default';
}

const { project, variant = 'default' } = Astro.props;

const description =
	variant === 'featured' && project.longDescription
		? project.longDescription
		: project.description;

const statusLabel = statusLabels[project.status];
const statusColor = statusColors[project.status];
const maxTags = variant === 'featured' ? project.techStack.length : 4;
const visibleTech = project.techStack.slice(0, maxTags);
const remainingCount = project.techStack.length - maxTags;

const colorMap: Record<string, { bg: string; border: string; text: string }> = {
	teal:       { bg: 'var(--color-teal-10)', border: 'var(--color-teal-20)', text: 'var(--color-teal)' },
	terracotta: { bg: 'var(--color-terracotta-10)', border: 'var(--color-terracotta-20)', text: 'var(--color-terracotta)' },
	amber:      { bg: 'var(--color-amber-10)', border: 'rgba(212, 154, 58, 0.25)', text: 'var(--color-amber)' },
	sage:       { bg: 'var(--color-sage-10)', border: 'rgba(90, 138, 110, 0.25)', text: 'var(--color-sage)' },
	burgundy:   { bg: 'var(--color-burgundy-10)', border: 'rgba(122, 51, 69, 0.25)', text: 'var(--color-burgundy)' },
};
---

<article class:list={['dev-card', variant]} data-animate="fade-up">
	<div class="card-image">
		{project.img ? (
			<img
				src={project.img}
				alt={project.imgAlt || ''}
				loading="lazy"
				decoding="async"
			/>
		) : (
			<div class="img-placeholder" aria-hidden="true">
				<Icon icon="code" size="3rem" />
			</div>
		)}
	</div>

	<div class="card-body">
		<div class="card-meta">
			<span class="status" style={`--status-color: ${statusColor}`}>
				<span class="status-dot" aria-hidden="true"></span>
				{statusLabel}
			</span>
			<span class="year">{project.year}</span>
		</div>

		<h3 class="card-title">{project.title}</h3>
		<p class="card-description">{description}</p>

		<div class="tech-stack">
			{visibleTech.map((tech) => {
				const c = colorMap[tech.color] || colorMap.teal;
				return (
					<span
						class="tech-pill"
						style={`--pill-bg: ${c.bg}; --pill-border: ${c.border}; --pill-text: ${c.text};`}
					>
						{tech.name}
					</span>
				);
			})}
			{remainingCount > 0 && (
				<span class="tech-pill tech-more">+{remainingCount}</span>
			)}
		</div>

		<div class="card-actions">
			{project.demoUrl && (
				<a
					href={project.demoUrl}
					class="action-btn action-primary"
					target="_blank"
					rel="noopener noreferrer"
				>
					<Icon icon="globe" size="1.1em" />
					Ver projeto
					<Icon icon="arrow-square-out" size="0.9em" />
				</a>
			)}
			{project.repoUrl && (
				<a
					href={project.repoUrl}
					class="action-btn action-ghost"
					target="_blank"
					rel="noopener noreferrer"
				>
					<Icon icon="github-logo" size="1.1em" />
					Código
				</a>
			)}
		</div>
	</div>
</article>

<style>
	/* ========================================
	   Base Card Styles
	   ======================================== */

	.dev-card {
		background: color-mix(in oklab, var(--color-bg-primary) 88%, transparent);
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-xl);
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		transition:
			transform var(--transition-default),
			box-shadow var(--transition-default),
			border-color var(--duration-normal) var(--ease-out);
	}

	.dev-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-md);
		border-color: var(--color-border-emphasis);
	}

	/* ========================================
	   Default Variant (vertical card)
	   ======================================== */

	.dev-card.default {
		display: flex;
		flex-direction: column;
	}

	.dev-card.default .card-image {
		aspect-ratio: 16 / 9;
		overflow: hidden;
		position: relative;
	}

	.dev-card.default .card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: var(--photo-warmth);
		transition: transform var(--transition-slow);
	}

	.dev-card.default:hover .card-image img {
		transform: scale(1.03);
	}

	.dev-card.default .card-body {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
		padding: var(--space-6);
		flex: 1;
	}

	/* ========================================
	   Featured Variant (horizontal hero card)
	   ======================================== */

	.dev-card.featured {
		display: grid;
		grid-template-columns: 1fr;
	}

	.dev-card.featured .card-image {
		aspect-ratio: 16 / 9;
		overflow: hidden;
		position: relative;
	}

	.dev-card.featured .card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: var(--photo-warmth);
		transition: transform var(--transition-slow);
	}

	.dev-card.featured:hover .card-image img {
		transform: scale(1.02);
	}

	.dev-card.featured .card-body {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		padding: var(--space-8);
	}

	.dev-card.featured .card-title {
		font-size: var(--text-h1);
	}

	.dev-card.featured .card-description {
		font-size: var(--text-body-lg);
		-webkit-line-clamp: unset;
	}

	@media (min-width: 50em) {
		.dev-card.featured {
			grid-template-columns: 1fr 1fr;
		}

		.dev-card.featured .card-image {
			aspect-ratio: auto;
			min-height: 320px;
		}

		.dev-card.featured .card-body {
			padding: var(--space-10);
			justify-content: center;
		}

		.dev-card.featured .card-title {
			font-size: var(--text-display);
		}
	}

	/* ========================================
	   Image Placeholder (gradient + icon)
	   ======================================== */

	.img-placeholder {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--gradient-membrane);
		color: var(--color-text-on-accent);
		opacity: var(--opacity-heavy);
	}

	/* ========================================
	   Card Meta (status + year)
	   ======================================== */

	.card-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-3);
	}

	.status {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		font-size: var(--text-xs);
		font-weight: var(--weight-medium);
		color: var(--status-color);
		text-transform: uppercase;
		letter-spacing: var(--tracking-label);
	}

	.status-dot {
		width: 8px;
		height: 8px;
		border-radius: var(--radius-full);
		background: var(--status-color);
		box-shadow: 0 0 6px var(--status-color);
	}

	.year {
		font-size: var(--text-xs);
		color: var(--color-text-tertiary);
		font-weight: var(--weight-regular);
		font-family: var(--font-mono);
	}

	/* ========================================
	   Title & Description
	   ======================================== */

	.card-title {
		font-size: var(--text-h3);
		font-family: var(--font-serif);
		color: var(--color-text-primary);
		letter-spacing: var(--tracking-heading);
		line-height: var(--leading-heading);
		margin: 0;
	}

	.card-description {
		font-size: var(--text-body);
		color: var(--color-text-secondary);
		line-height: var(--leading-body);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	/* ========================================
	   Tech Stack Pills
	   ======================================== */

	.tech-stack {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		margin-top: var(--space-1);
	}

	.tech-pill {
		display: inline-flex;
		align-items: center;
		padding: var(--space-1) var(--space-3);
		font-size: var(--text-xs);
		font-weight: var(--weight-medium);
		color: var(--pill-text);
		background: var(--pill-bg);
		border: 1px solid var(--pill-border);
		border-radius: var(--radius-full);
		white-space: nowrap;
		letter-spacing: var(--tracking-small);
	}

	.tech-more {
		--pill-bg: var(--color-bg-secondary);
		--pill-border: var(--color-border-default);
		--pill-text: var(--color-text-tertiary);
	}

	/* ========================================
	   Action Buttons
	   ======================================== */

	.card-actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
		margin-top: auto;
		padding-top: var(--space-3);
	}

	.action-btn {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		padding: var(--space-2) var(--space-4);
		border-radius: var(--radius-full);
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		text-decoration: none;
		transition:
			transform var(--transition-fast),
			background-color var(--transition-default),
			box-shadow var(--transition-default);
		min-height: 44px;
		white-space: nowrap;
	}

	.action-primary {
		background: var(--color-terracotta);
		color: var(--color-text-on-accent);
		border: 1px solid var(--color-terracotta-dark);
		box-shadow: var(--shadow-sm);
	}

	.action-primary:hover {
		background: var(--color-terracotta-light);
		transform: translateY(-1px);
		box-shadow: var(--shadow-md), var(--shadow-glow-warm);
	}

	.action-primary:focus-visible {
		outline: var(--focus-ring);
		outline-offset: var(--focus-ring-offset);
	}

	.action-ghost {
		background: color-mix(in oklab, var(--color-bg-primary) 80%, transparent);
		color: var(--color-text-secondary);
		border: 1px solid var(--color-border-default);
		box-shadow: var(--shadow-sm);
	}

	.action-ghost:hover {
		color: var(--color-text-primary);
		border-color: var(--color-border-emphasis);
		transform: translateY(-1px);
	}

	.action-ghost:focus-visible {
		outline: var(--focus-ring);
		outline-offset: var(--focus-ring-offset);
	}
</style>
