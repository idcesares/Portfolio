---
import Icon from './Icon.astro';
import ThemeToggle from './ThemeToggle.astro';
import SearchBox from './SearchBox.astro';

/** Main menu items */
const textLinks: { label: string; href: string; prefetch?: 'load' | 'hover' | 'viewport' }[] = [
	{ label: 'Home', href: '/', prefetch: 'load' },
	{ label: 'Trabalhos', href: '/work', prefetch: 'load' },
	{ label: 'Blog', href: '/blog', prefetch: 'load' },
	{ label: 'Dev', href: '/dev' },
	{ label: 'Sobre', href: '/about' }];
---

<nav>
	<div class="nav-shell">
		<div class="menu-header">
			<a href="/" class="site-title" aria-label="Isaac D'Césares">
				<span class="monogram" aria-hidden="true"><span class="monogram-d">d</span><span class="monogram-c">c</span></span>
			</a>
			<div class="nav-actions">
				<button class="search-toggle" id="search-toggle" type="button" aria-label="Open search">
					<Icon icon="magnifying-glass" />
				</button>
				<menu-button>
					<template>
						<button class="menu-button" aria-expanded="false">
							<span class="sr-only">Menu</span>
							<Icon icon="list" />
						</button>
					</template>
				</menu-button>
			</div>
		</div>
		<noscript>
		<ul class="nav-items">
				{
					textLinks.map(({ label, href, prefetch }) => (
						<li>
							<a
								aria-current={Astro.url.pathname === href}
								class:list={[
									'link',
									{
										active:
											Astro.url.pathname === href ||
											(href !== '/' && Astro.url.pathname.startsWith(href)),
									},
								]}
								href={href}
								data-astro-prefetch={prefetch}
							>
								{label}
							</a>
						</li>
					))
				}
			</ul>
		</noscript>

		<div id="menu-content" hidden>
			<ul class="nav-items">
				{
					textLinks.map(({ label, href, prefetch }) => (
						<li>
							<a
								aria-current={Astro.url.pathname === href}
								class:list={[
									'link',
									{
										active:
											Astro.url.pathname === href ||
											(href !== '/' && Astro.url.pathname.startsWith(href)),
									},
								]}
								href={href}
								data-astro-prefetch={prefetch}
							>
								{label}
							</a>
						</li>
					))
				}
			</ul>
			<div class="menu-footer">
				<button class="search-toggle desktop-search-btn" id="search-toggle-desktop" type="button" aria-label="Open search">
					<Icon icon="magnifying-glass" />
				</button>

				<div class="theme-toggle">
					<ThemeToggle />
				</div>
			</div>
		</div>
	</div>
	<div class="search-overlay" id="search-overlay" hidden>
		<div class="search-overlay-content">
			<div class="search-modal-header">
				<h2>Busca</h2>
				<button class="search-close" id="search-close" type="button" aria-label="Close search">
					<Icon icon="arrow-left" />
				</button>
			</div>
			<SearchBox placeholder="Pesquise posts e projetos..." />
		</div>
	</div>
</nav>

<script>
	class MenuButton extends HTMLElement {
		constructor() {
			super();

			// Inject menu toggle button when JS runs.
			this.appendChild(this.querySelector('template')!.content.cloneNode(true));
			const btn = this.querySelector('button')!;

			// Hide menu (shown by default to support no-JS browsers).
			const menu = document.getElementById('menu-content')!;
			menu.hidden = true;
			// Add "menu-content" class in JS to avoid covering content in non-JS browsers.
			menu.classList.add('menu-content');

			/** Set whether the menu is currently expanded or collapsed. */
			const setExpanded = (expand: boolean) => {
				btn.setAttribute('aria-expanded', expand ? 'true' : 'false');
				menu.hidden = !expand;
			};

			// Toggle menu visibility when the menu button is clicked.
			btn.addEventListener('click', () => setExpanded(menu.hidden));

			// Hide menu button for large screens.
			const handleViewports = (e: MediaQueryList | MediaQueryListEvent) => {
				setExpanded(e.matches);
				btn.hidden = e.matches;
			};
			const mediaQueries = window.matchMedia('(min-width: 50em)');
			handleViewports(mediaQueries);
			mediaQueries.addEventListener('change', handleViewports);
		}
	}
	customElements.define('menu-button', MenuButton);

	// Search overlay functionality
	class SearchToggle {
		constructor() {
			this.init();
		}

		init() {
			const searchToggle = document.getElementById('search-toggle');
			const searchToggleDesktop = document.getElementById('search-toggle-desktop');
			const searchOverlay = document.getElementById('search-overlay');
			const searchClose = document.getElementById('search-close');
			const searchInput = document.getElementById('search-input');

			if (!searchOverlay || !searchClose) return;

			const openSearch = () => {
				searchOverlay.hidden = false;
				document.dispatchEvent(new CustomEvent('searchOverlayOpened'));
				// Focus the input after a small delay to ensure the modal is rendered
				setTimeout(() => {
					searchInput?.focus();
				}, 100);
			};

			const closeSearch = () => {
				searchOverlay.hidden = true;
			};

			// Mobile search toggle
			if (searchToggle) {
				searchToggle.addEventListener('click', openSearch);
			}

			// Desktop search toggle
			if (searchToggleDesktop) {
				searchToggleDesktop.addEventListener('click', openSearch);
			}

			// Close search overlay
			searchClose.addEventListener('click', closeSearch);

			// Close on escape key
			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape' && !searchOverlay.hidden) {
					closeSearch();
				}
			});

			// Close on overlay background click
			searchOverlay.addEventListener('click', (e) => {
				if (e.target === searchOverlay) {
					closeSearch();
				}
			});
		}
	}

	// Initialize components
	function initNav() {
		new SearchToggle();

		const nav = document.querySelector('nav');
		if (!nav) return;

		let ticking = false;
		const updateNavState = () => {
			const scrolled = window.scrollY > 12;
			nav.setAttribute('data-scrolled', scrolled ? 'true' : 'false');
			ticking = false;
		};

		updateNavState();
		window.addEventListener('scroll', () => {
			if (!ticking) {
				window.requestAnimationFrame(updateNavState);
				ticking = true;
			}
		});
	}

	// Initialize on DOM load
	document.addEventListener('DOMContentLoaded', initNav);
</script>

<style>
	nav {
		z-index: var(--z-nav);
		position: sticky;
		top: 0;
		padding: var(--space-5) var(--space-6) 0;
		font-family: var(--font-sans);
		font-weight: var(--weight-medium);
		margin-bottom: var(--space-12);
		display: flex;
		justify-content: center;
	}

	.nav-shell {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
		padding: var(--space-3) var(--space-4);
		border-radius: var(--radius-xl);
		border: 1px solid var(--color-border-default);
		background: color-mix(in oklab, var(--color-bg-primary) 80%, transparent);
		backdrop-filter: blur(var(--space-3));
		box-shadow: var(--shadow-sm);
		transition: box-shadow var(--transition-default), background-color var(--transition-default);
		position: relative;
		overflow: hidden;
		width: min(90rem, calc(100% - 3rem));
	}

	.nav-shell::after {
		content: '';
		position: absolute;
		left: 12%;
		right: 12%;
		bottom: 0;
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent,
			color-mix(in oklab, var(--color-teal) 55%, transparent),
			transparent
		);
		opacity: 0.45;
	}

	nav[data-scrolled='true'] .nav-shell {
		background: color-mix(in oklab, var(--color-bg-primary) 92%, transparent);
		box-shadow: var(--shadow-md);
		border-color: color-mix(in oklab, var(--color-border-default) 70%, transparent);
	}

	.menu-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: var(--space-2);
		padding: var(--space-1) var(--space-1) 0;
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: var(--space-2);
	}

	.search-toggle {
		position: relative;
		display: flex;
		border: 0;
		border-radius: var(--radius-full);
		padding: var(--space-2);
		font-size: var(--text-body);
		color: var(--color-text-tertiary);
		background: color-mix(in oklab, var(--color-bg-primary) 72%, transparent);
		border: 1px solid color-mix(in oklab, var(--color-border-emphasis) 60%, transparent);
		box-shadow: none;
		cursor: pointer;
		min-height: 44px;
		min-width: 44px;
		align-items: center;
		justify-content: center;
		transition: color var(--transition-default);
	}

	.search-toggle:hover {
		color: var(--color-text-primary);
	}

	.desktop-search-btn {
		display: none;
	}

	.search-overlay {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: var(--color-overlay-bg);
		backdrop-filter: blur(var(--space-2));
		z-index: var(--z-overlay);
		display: flex;
		align-items: flex-start;
		justify-content: center;
		padding: var(--space-8) var(--space-4);
		opacity: 1;
		transition: opacity var(--transition-default);
	}

	.search-overlay[hidden] {
		display: none;
		opacity: 0;
	}

	.search-overlay-content {
		width: 100%;
		max-width: var(--container-sm);
		margin-top: var(--space-16);
		background: var(--color-bg-primary);
		border-radius: var(--radius-lg);
		padding: var(--space-6);
		box-shadow: var(--shadow-lg);
		border: 1px solid var(--color-border-default);
		transform: translateY(0);
		transition: transform var(--transition-default);
	}

	.search-modal-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: var(--space-6);
	}

	.search-modal-header h2 {
		margin: 0;
		font-size: var(--text-h2);
		font-weight: var(--weight-semibold);
		color: var(--color-text-primary);
	}

	.search-close {
		display: flex;
		align-items: center;
		justify-content: center;
		width: var(--space-10);
		height: var(--space-10);
		min-height: 44px;
		min-width: 44px;
		background: none;
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-md);
		color: var(--color-text-tertiary);
		cursor: pointer;
		transition: all var(--transition-default);
	}

	.search-close:hover {
		background: var(--color-bg-tertiary);
		color: var(--color-text-primary);
		border-color: var(--color-border-emphasis);
	}

	.site-title {
		display: flex;
		gap: var(--space-2);
		align-items: center;
		line-height: var(--leading-display);
		color: var(--color-text-primary);
		text-decoration: none;
		font-family: var(--font-serif);
		font-weight: var(--weight-semibold);
		font-size: var(--text-h4);
	}

	.monogram {
		display: inline-flex;
		font-family: var(--font-serif);
		font-weight: var(--weight-bold);
		font-size: var(--text-h3);
		line-height: 1;
		letter-spacing: var(--tracking-display);
		user-select: none;
	}

	.monogram-d {
		color: var(--color-terracotta);
	}

	.monogram-c {
		color: var(--color-teal);
	}

	.menu-button {
		position: relative;
		display: flex;
		border: 0;
		border-radius: var(--radius-full);
		padding: var(--space-2);
		font-size: var(--text-h3);
		color: var(--color-text-tertiary);
		background: color-mix(in oklab, var(--color-bg-primary) 72%, transparent);
		border: 1px solid color-mix(in oklab, var(--color-border-emphasis) 60%, transparent);
		box-shadow: none;
		min-height: 44px;
		min-width: 44px;
		align-items: center;
		justify-content: center;
	}

	.menu-button[aria-expanded='true'] {
		color: var(--color-text-on-accent);
		background: var(--gradient-membrane);
	}

	.menu-button[hidden] {
		display: none;
	}

	.menu-content {
		position: relative;
	}

	.nav-items {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		font-size: var(--text-h4);
		line-height: var(--leading-label);
		letter-spacing: var(--tracking-small);
		list-style: none;
		padding: var(--space-4) 0;
		background-color: transparent;
		border: 0;
		align-items: center;
		width: 100%;
	}

	.link {
		display: inline-block;
		color: var(--color-text-tertiary);
		text-decoration: none;
		position: relative;
		padding: var(--space-1) 0;
		transition: color var(--transition-default);
	}

	.link::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: calc(var(--space-1) * -0.5);
		width: 0%;
		height: 2px;
		background: var(--color-teal);
		transition: width var(--transition-default);
	}

	.link:hover::after,
	.link:focus::after {
		width: 100%;
	}

	.link.active {
		color: var(--color-text-primary);
	}

	.link.active::after {
		width: 100%;
	}

	.menu-footer {
		--icon-size: var(--text-h2);
		--icon-padding: var(--space-2);

		display: flex;
		justify-content: space-between;
		gap: var(--space-3);
		padding: 0 0 var(--space-3);
		background-color: transparent;
		border-radius: 0;
		border: 0;
		box-shadow: none;
	}

	.theme-toggle {
		display: flex;
		align-items: center;
	}

	@media (min-width: 50em) {
		nav {
			padding: var(--space-8) var(--space-16) 0;
		}

		.nav-shell {
			display: grid;
			grid-template-columns: auto 1fr auto;
			align-items: center;
			gap: var(--space-8);
			padding: var(--space-3) var(--space-6);
			width: min(88rem, calc(100% - var(--space-16)));
		}

		.menu-header {
			padding: 0;
			grid-column: 1;
			display: flex;
			justify-content: flex-start;
			align-items: center;
		}

		.nav-actions {
			display: none;
		}

		.search-overlay-content {
			margin-top: var(--space-24);
			max-width: var(--container-md);
		}

		.search-toggle {
			font-size: var(--text-body);
			padding: var(--space-2);
		}

		.menu-footer .search-toggle {
			display: flex;
		}

		.desktop-search-btn {
			display: flex;
		}

		.site-title {
			font-size: var(--text-h3);
		}

		.monogram {
			font-size: var(--text-h2);
		}

		.menu-content {
			display: flex;
			grid-column: 2;
			justify-content: center;
		}

		.nav-items {
			flex-direction: row;
			font-size: var(--text-body);
			gap: var(--space-8);
			padding: 0;
			justify-content: center;
			width: 100%;
		}

		.link {
			padding: var(--space-1) 0;
			transition:
				color var(--transition-default),
				background-color var(--transition-default);
		}

		.link:hover,
		.link:focus {
			color: var(--color-text-primary);
		}

		.link.active {
			color: var(--color-teal);
		}

		.menu-footer {
			--icon-padding: var(--space-1);

			grid-column: 3;
			justify-self: flex-end;
			align-items: center;
			padding: 0;
			background-color: transparent;
			box-shadow: none;
			display: flex;
			gap: var(--space-3);
		}
	}

	@media (forced-colors: active) {
		.link.active {
			color: SelectedItem;
		}
	}
</style>
