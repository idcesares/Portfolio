---
// Ensure the Icon component is correctly imported from your project structure.
import WhatsAppIcon from './WhatsAppIcon.astro';
---

<a href="https://api.whatsapp.com/send?phone=5521983291513" class="float" target="_blank">
    <WhatsAppIcon style="my-float"/>
</a>

<style>
    .float {
	position: fixed;
	width: var(--space-16);
	height: var(--space-16);
	bottom: var(--space-10);
	right: var(--space-10);
	background-color: #25d366; /* WhatsApp brand green — intentionally not from design system */
	color: var(--color-cream);
	border-radius: var(--radius-full);
	text-align: center;
	font-size: var(--text-h2);
	box-shadow: var(--shadow-md);
	z-index: var(--z-nav);
	transition: transform var(--transition-default),
		box-shadow var(--transition-default);
    }

    .float:hover {
	transform: scale(1.08);
	box-shadow: var(--shadow-lg);
    }

    .my-float {
	margin-top: var(--space-4);
    }
</style>