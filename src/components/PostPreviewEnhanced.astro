---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

interface Props {
	post: CollectionEntry<'blog'>;
	variant?: 'default' | 'compact';
}

const { post, variant = 'default' } = Astro.props;
const { data, id } = post;
const isRemoteImage = /^https?:\/\//i.test(data.img);

// Format date for display
const updatedDate = new Date(data.updatedDate);
const formattedDate = updatedDate.toLocaleDateString('pt-BR', {
	year: 'numeric',
	month: 'long',
	day: 'numeric'
});
---

<li 
	class:list={['post-item', variant]}
	data-filterable-item
	data-tags={data.tags.join(', ')}
	data-title={data.title}
	data-description={data.description}
	data-updated-date={data.updatedDate.toISOString()}
>
	<a class="card" href={`/blog/${id}`}>
		{variant === 'compact' ? (
			<>
				<div class="content">
					<div class="meta">
						<time class="date">{formattedDate}</time>
						<div class="tags">
							{data.tags.slice(0, 2).map((tag) => (
								<span class="tag">{tag}</span>
							))}
							{data.tags.length > 2 && (
								<span class="tag-more">+{data.tags.length - 2}</span>
							)}
						</div>
					</div>
					<h3 class="title">{data.title}</h3>
					<p class="description">{data.description}</p>
				</div>
				<div class="image-container">
					{
						isRemoteImage ? (
							<img src={data.img} alt={data.img_alt || ''} width="400" height="300" loading="lazy" decoding="async" />
						) : (
							<Image src={data.img} alt={data.img_alt || ''} width={400} height={300} loading="lazy" decoding="async" />
						)
					}
				</div>
			</>
		) : (
			<>
				<span class="title">{data.title}</span>
				{
					isRemoteImage ? (
						<img src={data.img} alt={data.img_alt || ''} width="600" height="400" loading="lazy" decoding="async" />
					) : (
						<Image src={data.img} alt={data.img_alt || ''} width={600} height={400} loading="lazy" decoding="async" />
					)
				}
			</>
		)}
	</a>
</li>

<style>
	.post-item {
		list-style: none;
	}

	/* Default (original) style */
	.post-item.default .card {
		display: grid;
		grid-template: auto 1fr / auto 1fr;
		height: 12rem;
		background: var(--color-bg-primary);
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-lg);
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		font-family: var(--font-serif);
		font-size: var(--text-lg);
		font-weight: var(--weight-medium);
		transition: box-shadow var(--transition-default), transform var(--transition-default);
	}

	.post-item.default .card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-3px);
	}

	.post-item.default .title {
		grid-area: 1 / 1 / 2 / 2;
		z-index: 1;
		margin: var(--space-3);
		padding: var(--space-2) var(--space-3);
		background: color-mix(in oklab, var(--color-bg-primary) 80%, transparent);
		color: var(--color-text-primary);
		border-radius: var(--radius-sm);
		backdrop-filter: blur(var(--space-2));
	}

	.post-item.default img {
		grid-area: 1 / 1 / 3 / 3;
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: var(--photo-warmth);
	}

	/* Compact style */
	.post-item.compact .card {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: var(--space-4);
		padding: var(--space-4);
		background: color-mix(in oklab, var(--color-bg-primary) 88%, transparent);
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-md);
		text-decoration: none;
		color: inherit;
		transition: all var(--duration-normal) var(--ease-out);
		min-height: 120px;
	}

	.post-item.compact .card:hover {
		background: color-mix(in oklab, var(--color-bg-primary) 92%, transparent);
		border-color: var(--color-border-emphasis);
		transform: translateY(-2px);
		box-shadow: var(--shadow-md);
	}

	.post-item.compact .content {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		min-width: 0;
	}

	.post-item.compact .meta {
		display: flex;
		flex-direction: column;
		gap: var(--space-1);
	}

	.post-item.compact .date {
		font-size: var(--text-xs);
		color: var(--color-text-tertiary);
		font-weight: var(--weight-regular);
	}

	.post-item.compact .tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-1);
	}

	.post-item.compact .tag {
		font-size: var(--text-xs);
		padding: 2px var(--space-2);
		background: color-mix(in oklab, var(--color-teal) 20%, var(--color-bg-primary));
		color: var(--color-teal);
		border-radius: var(--radius-full);
		font-weight: var(--weight-medium);
		text-transform: uppercase;
		letter-spacing: var(--tracking-label);
	}

	.post-item.compact .tag-more {
		font-size: var(--text-xs);
		padding: 2px var(--space-2);
		background: var(--color-bg-secondary);
		color: var(--color-text-tertiary);
		border-radius: var(--radius-full);
		font-weight: var(--weight-medium);
	}

	.post-item.compact .title {
		font-size: var(--text-md);
		font-weight: var(--weight-semibold);
		color: var(--color-text-primary);
		line-height: var(--leading-subheading);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-item.compact .description {
		font-size: var(--text-base);
		color: var(--color-text-secondary);
		line-height: var(--leading-body);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-item.compact .image-container {
		width: 100px;
		height: 80px;
		flex-shrink: 0;
		border-radius: var(--radius-sm);
		overflow: hidden;
	}

	.post-item.compact img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: var(--photo-warmth);
	}

	/* Responsive adjustments */
	@media (min-width: 50em) {
		.post-item.default .card {
			height: 22rem;
			border-radius: var(--radius-xl);
		}

		.post-item.default .title {
			border-radius: var(--radius-md);
		}

		.post-item.compact .card {
			min-height: 100px;
		}

		.post-item.compact .image-container {
			width: 120px;
			height: 90px;
		}

		.post-item.compact .meta {
			flex-direction: row;
			justify-content: space-between;
			align-items: center;
		}
	}
</style>
